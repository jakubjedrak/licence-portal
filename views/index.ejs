<div class="hero-section bg-primary text-white py-5 mb-5 rounded">
    <div class="row align-items-center">
        <div class="col-lg-6">
            <h1 class="display-4 fw-bold mb-4"><%= t('general.welcome') %></h1>
            <p class="lead mb-4">
                Efficiently manage and report unused software licenses and accounts. 
                Save costs and optimize your organization's software portfolio.
            </p>
            <div class="d-grid gap-2 d-md-flex">
                <a href="/auth/register" class="btn btn-light btn-lg me-md-2">
                    <i class="bi bi-person-plus me-2"></i>
                    <%= t('general.register') %>
                </a>
                <a href="/auth/login" class="btn btn-outline-light btn-lg">
                    <i class="bi bi-box-arrow-in-right me-2"></i>
                    <%= t('general.login') %>
                </a>
            </div>
        </div>
        <div class="col-lg-6 text-center">
            <i class="bi bi-shield-check display-1"></i>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="bi bi-ticket-detailed text-primary display-4 mb-3"></i>
                <h5 class="card-title">Easy Ticket System</h5>
                <p class="card-text">
                    Submit license release requests with detailed information and track their progress through completion.
                </p>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="bi bi-graph-up text-success display-4 mb-3"></i>
                <h5 class="card-title">Cost Savings</h5>
                <p class="card-text">
                    Track estimated and confirmed savings from released licenses to demonstrate value to your organization.
                </p>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="bi bi-grid-3x3-gap text-info display-4 mb-3"></i>
                <h5 class="card-title">Software Catalog</h5>
                <p class="card-text">
                    Comprehensive catalog of software and services with cost information and deactivation instructions.
                </p>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-12">
        <div class="card bg-light">
            <div class="card-body text-center py-5">
                <h3 class="mb-4">Get Started Today</h3>
                <p class="lead mb-4">
                    Join your organization's license optimization efforts. Register with your @zf-lifetec.com email address.
                </p>
                <a href="/auth/register" class="btn btn-primary btn-lg">
                    <i class="bi bi-arrow-right me-2"></i>
                    Create Account
                </a>
            </div>
        </div>
    </div>
</div>