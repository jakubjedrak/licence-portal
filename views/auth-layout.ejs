<!DOCTYPE html>
<html lang="<%= currentLanguage %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - License Portal</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link href="/css/auth.css" rel="stylesheet">
</head>
<body class="bg-light">
    <!-- Navigation (simplified) -->
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-shield-check me-2"></i>
                License Portal
            </a>
            
            <!-- Language Switcher -->
            <div class="dropdown">
                <button class="btn btn-outline-light btn-sm dropdown-toggle" type="button" id="languageDropdown" data-bs-toggle="dropdown">
                    <i class="bi bi-translate me-1"></i>
                    <%= currentLanguage.toUpperCase() %>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <% supportedLanguages.forEach(lang => { %>
                        <li>
                            <form method="POST" action="/language" class="d-inline">
                                <input type="hidden" name="language" value="<%= lang %>">
                                <button type="submit" class="dropdown-item <%= currentLanguage === lang ? 'active' : '' %>">
                                    <%= lang.toUpperCase() %>
                                </button>
                            </form>
                        </li>
                    <% }); %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-sm mt-5">
                    <div class="card-body p-5">
                        <!-- Flash Messages -->
                        <%- include('partials/flash-messages') %>
                        
                        <!-- Page Content -->
                        <%- body %>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="text-center mt-5 py-3">
        <div class="container">
            <p class="text-muted mb-0">&copy; 2024 License Portal. All rights reserved.</p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>